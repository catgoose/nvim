{
  "angular.suggest.includeCompletionsWithSnippetText": true,
  "angular.suggest.includeAutomaticOptionalChainCompletions": true,
  "angular.trace.server": "verbose",
  "angular.enable-strict-mode-prompt": true,
  "coc.preferences.formatOnSaveFiletypes": [
    "sh",
    "css",
    "scss",
    "sass",
    "html",
    "javascript",
    "javascriptreact",
    "json",
    "lua",
    "typescript",
    "typescript.tsx",
    "typescriptreact",
    "vim"
  ],
  "coc.preferences.enableMarkdown": false,
  "codeLens.enable": true,
  "codeLens.position": "eol",
  "codeLens.separator": "»",
  "codeLens.subseparator": " / ",
  "diagnostic.errorSign": "✘",
  "diagnostic.warningSign": "!!",
  "diagnostic.infoSign": "?",
  "diagnostic.hintSign": "•",
  "diagnostic.signLevel": "warning",
  "diagnostic.virtualText": true,
  "diagnostic.virtualTextLevel": "warning",
  "diagnostic.virtualTextCurrentLineOnly": false,
  "diagnostic.virtualTextPrefix": "",
  "diagnostic.virtualTextLines": 5,
  "diagnostic.virtualTextLineSeparator": " \\ ",
  "diagnostic.floatConfig": {
    "border": true,
    "winblend": 10,
    "focusable": true,
    "maxHeight": 500,
    "maxWidth": 80
  },
  "eslint.enable": true,
  "eslint.run": "onSave",
  "eslint.autoFixOnSave": true,
  "explorer.file.child.template": "[git | 2] [selection | clip | 1] [indent][icon | 1] [diagnosticError & 1][filename omitCenter 1][modified][readonly] [linkIcon & 1][link growRight 1 omitCenter 5]",
  "explorer.icon.enableNerdfont": true,
  "explorer.icon.source": "nvim-web-devicons",
  "explorer.position": "floating",
  "explorer.floating.width": 60,
  "explorer.floating.height": 40,
  "html.autoClosingTags": true,
  "javascript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBraces": true,
  "javascript.autoClosingTags": true,
  "javascript.referencesCodeLens.enable": true,
  "javascript.implementationsCodeLens.enable": true,
  "prettier.enable": true,
  "prettier.singleQuote": false,
  "prettier.disableLanguages": [],
  "snippets.userSnippetsDirectory": "~/.config/ultisnips",
  "suggest.maxCompleteItemCount": 20,
  "sumneko-lua.enableNvimLuaDev": true,
  "snippets.priority": 10,
  "typescript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBraces": true,
  "typescript.autoClosingTags": true,
  "typescript.referencesCodeLens.enable": true,
  "typescript.implementationsCodeLens.enable": true,
  "typescript.referencesCodeLens.showOnAllFunctions": false,
  "workspace.workspaceFolderCheckCwd": false,
  "workspace.bottomUpFiletypes": [
    ".git"
  ],
  "workspace.workspaceFolderFallbackCwd": true,
  "Lua.telemetry.enable": true,
  "coc.preferences.extensionUpdateCheck": "daily"
}
